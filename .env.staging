# Frontend environment — staging
# These are baked into the Next.js bundle at docker build time (--build-arg).
# NEXT_PUBLIC_* values are visible in the browser — do NOT put secrets here.

NEXT_PUBLIC_API_URL=https://staging.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://staging.yourdomain.com/ws
COOKIE_SECURE=false
